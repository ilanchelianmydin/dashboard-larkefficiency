<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LARK AUTOMATION CLASH — SEASON 1 × MYDIN</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --blue:#00B4FF; --green:#00FF9D; --yellow:#FFD700;
  --purple:#B14AFF; --bg:#04090F; --panel:#080F1E;
  --card:#0B1628; --muted:#3A6080;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:#C2DCF0;font-family:'Rajdhani',sans-serif;overflow-x:hidden;min-height:100vh;cursor:crosshair;}

/* GRID OVERLAY */
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.1) 2px,rgba(0,0,0,0.1) 4px);pointer-events:none;z-index:999;}
canvas#bg{position:fixed;inset:0;z-index:0;pointer-events:none;}

.wrap{position:relative;z-index:1;max-width:1000px;margin:0 auto;padding:0 28px 100px;}

/* HEADER SECTION */
header{text-align:center;padding:70px 0 50px;position:relative;}
.s1-badge{
  display:inline-flex;align-items:center;gap:10px;
  border:1px solid var(--purple);padding:5px 18px;margin-bottom:28px;
  font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:4px;color:var(--purple);
  position:relative;overflow:hidden;
  animation:bdg 3s ease-in-out infinite;
}
@keyframes bdg{0%,100%{box-shadow:0 0 8px rgba(177,74,255,.3)}50%{box-shadow:0 0 20px rgba(177,74,255,.6)}}

.main-title{
  font-family:'Orbitron',sans-serif;font-size:clamp(30px,7vw,72px);
  font-weight:900;line-height:.95;letter-spacing:2px;text-transform:uppercase;
  color:#fff;text-shadow:0 0 30px rgba(0,180,255,.7);
}
.title-ghost{display:block;color:transparent;-webkit-text-stroke:1px rgba(0,180,255,.35);font-size:.62em;letter-spacing:8px;margin-top:6px;}

.chip{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:2px;padding:4px 14px;border:1px solid;margin:10px 5px;display:inline-block;}
.c-blue{color:var(--blue);border-color:rgba(0,180,255,.35);}
.c-gold{color:#0A0A0A;background:linear-gradient(90deg,var(--yellow),#FFA500);font-weight:700;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}

/* PRIZE DISPLAY */
.prize-box{
  background:var(--panel);border:1px solid rgba(255,215,0,.2);
  padding:44px 32px;text-align:center;position:relative;margin:40px 0;
}
.p-amt{
  font-family:'Orbitron',sans-serif;font-size:clamp(50px,10vw,90px);
  font-weight:900;color:var(--yellow);line-height:1;display:block;
  text-shadow:0 0 40px rgba(255,215,0,0.5);
}
.p-perks{display:flex;justify-content:center;gap:10px;margin-top:24px;flex-wrap:wrap;}
.pp{background:rgba(255,255,255,.05);padding:8px 15px;font-family:'Share Tech Mono',monospace;font-size:11px;border:1px solid rgba(255,255,255,0.1);}

/* COUNTDOWNS */
.clocks{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:48px;}
.clk{background:var(--panel);border:1px solid;padding:25px;text-align:center;}
.clk-r{border-color:var(--blue);}
.clk-c{border-color:var(--green);}
.unum{font-family:'Orbitron',sans-serif;font-size:32px;font-weight:700;display:block;}
.clk-r .unum{color:var(--blue);} .clk-c .unum{color:var(--green);}
.ulbl{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--muted);}

/* BUTTON */
.btn-reg{
  display:inline-block;padding:22px 60px;
  font-family:'Orbitron',sans-serif;font-weight:700;letter-spacing:3px;
  text-decoration:none;color:var(--bg);
  background:linear-gradient(135deg,var(--blue),var(--green));
  clip-path:polygon(15px 0%,100% 0%,calc(100% - 15px) 100%,0% 100%);
  transition:0.3s ease;
  box-shadow: 0 0 15px rgba(0, 255, 157, 0.3);
}
.btn-reg:hover{transform:scale(1.05);filter:brightness(1.2);box-shadow: 0 0 25px rgba(0, 255, 157, 0.6);}

@media(max-width:600px){ .clocks{grid-template-columns:1fr;} }
</style>
</head>
<body>
<canvas id="bg"></canvas>

<div class="wrap">
  <header>
    <div class="s1-badge">SEASON 1 — NOW LIVE</div>
    <h1 class="main-title">LARK AUTOMATION<br><span class="title-ghost">CHAMPIONSHIP</span></h1>
    <div class="sub-row">
      <span class="chip c-blue">MYDIN × LARK</span>
      <span class="chip c-gold">2025</span>
    </div>
  </header>

  <div class="prize-box">
    <div style="font-family:'Share Tech Mono';color:var(--muted);margin-bottom:10px;">// TOTAL PRIZE POOL //</div>
    <span class="p-amt" id="prize-disp">RM 0</span>
    <div class="p-perks">
      <div class="pp">🏆 CASH PRIZES</div>
      <div class="pp">📜 CERTIFICATES</div>
      <div class="pp">🎁 EXCLUSIVE REWARDS</div>
    </div>
  </div>

  <div class="clocks">
    <div class="clk clk-r">
      <div class="ulbl">REGISTRATION CLOSES: 27 APR</div>
      <div id="r-timer" class="unum">00:00:00:00</div>
      <div class="ulbl">DAYS : HRS : MIN : SEC</div>
    </div>
    <div class="clk clk-c">
      <div class="ulbl">COMPETITION DAY: 15 JUN</div>
      <div id="c-timer" class="unum">00:00:00:00</div>
      <div class="ulbl">DAYS : HRS : MIN : SEC</div>
    </div>
  </div>

  <div style="text-align:center;">
    <a href="https://mydin.sg.larksuite.com/share/base/form/shrlgXQ6YEDpr0zoojyz0rq2xtP" target="_blank" class="btn-reg" id="reg-btn">
      ⚡ REGISTER VIA LARK
    </a>
    <p style="margin-top:15px;font-family:'Share Tech Mono';font-size:12px;color:var(--muted);">SECURE YOUR SPOT — SEASON 1 ACCESS</p>
  </div>
</div>

<script>
// BACKGROUND CANVAS ANIMATION
const canvas = document.getElementById('bg');
const ctx = canvas.getContext('2d');
let w, h, particles = [];

function init() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    particles = [];
    for (let i = 0; i < 50; i++) {
        particles.push({
            x: Math.random() * w,
            y: Math.random() * h,
            size: Math.random() * 2,
            speed: Math.random() * 0.5 + 0.1
        });
    }
}

function animate() {
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = "rgba(0, 180, 255, 0.3)";
    particles.forEach(p => {
        p.y -= p.speed;
        if (p.y < 0) p.y = h;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
    });
    requestAnimationFrame(animate);
}

window.addEventListener('resize', init);
init();
animate();

// PRIZE COUNTER
let currentPrize = 0;
const targetPrize = 2000;
function animatePrize() {
    if (currentPrize < targetPrize) {
        currentPrize += 40;
        document.getElementById('prize-disp').innerText = `RM ${currentPrize.toLocaleString()}++`;
        requestAnimationFrame(animatePrize);
    } else {
        document.getElementById('prize-disp').innerText = `RM 2,000++`;
    }
}
setTimeout(animatePrize, 500);

// TIMERS (Set for 2025)
const regDate = new Date("April 27, 2025 23:59:59").getTime();
const compDate = new Date("June 15, 2025 08:00:00").getTime();

function updateTimer(target, elementId) {
    const now = new Date().getTime();
    const diff = target - now;
    if (diff < 0) { document.getElementById(elementId).innerText = "00:00:00:00"; return; }
    
    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const s = Math.floor((diff % (1000 * 60)) / 1000);
    
    document.getElementById(elementId).innerText = 
        `${String(d).padStart(2,'0')}:${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

setInterval(() => {
    updateTimer(regDate, 'r-timer');
    updateTimer(compDate, 'c-timer');
}, 1000);
</script>
</body>
</html>
